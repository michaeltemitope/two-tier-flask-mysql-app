# =============================================================
# .env.example
# Purpose : Template showing all required environment variables
#           Copy this file to .env and fill in your real values
# Usage   : cp .env.example .env
# WARNING : This file is safe to commit to Git
#           It contains NO real credentials — only placeholders
# =============================================================

# -------------------------------------------------------------
# FLASK APPLICATION + WAIT-FOR-DB SCRIPT
# These DB_* variables are shared between app.py and
# wait-for-db.sh — both run inside the Flask container
# DB_HOST must match the MySQL service name in docker-compose.yml
# DB_USER must match MYSQL_USER below
# DB_PASSWORD must match MYSQL_PASSWORD below
# DB_NAME must match MYSQL_DATABASE below
# -------------------------------------------------------------
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# -------------------------------------------------------------
# MYSQL CONTAINER INITIALIZATION
# Used exclusively by the official MySQL Docker image
# on first startup to create users and the database
# MYSQL_ROOT_PASSWORD → creates the root admin account
# MYSQL_USER         → creates a dedicated non-root app user
#                      must NOT be root (root is handled above)
# MYSQL_PASSWORD     → password for MYSQL_USER
#                      must match DB_PASSWORD above
# MYSQL_DATABASE     → creates this database and grants
#                      MYSQL_USER full access to it only
#                      must match DB_NAME above
# -------------------------------------------------------------
MYSQL_ROOT_PASSWORD=
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# -------------------------------------------------------------
# WAIT-FOR-DB RETRY TUNING — all optional
# Safe defaults are used inside the script if not set here
# DB_MAX_RETRIES    : number of connection attempts before giving up
# DB_RETRY_INTERVAL : base seconds between each retry attempt
# DB_MAX_SLEEP      : maximum seconds the backoff sleep can grow to
# -------------------------------------------------------------
DB_MAX_RETRIES=30
DB_RETRY_INTERVAL=2
DB_MAX_SLEEP=30
